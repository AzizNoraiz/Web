{% extends 'base.html.twig' %}

{% block title %}Casino Royal | Le 777{% endblock %}

{% block body %}
<div class="bg-casino min-vh-100 py-5 d-flex align-items-center" style="background: radial-gradient(circle, #2a1f00 0%, #000000 100%); overflow: hidden;">

    {# --- HEADER --- #}
    <div class="position-absolute top-0 end-0 p-4 d-flex align-items-center gap-3" style="z-index: 1000;">
        <div class="text-end">
            <div class="text-white-50 fw-bold text-uppercase small" style="letter-spacing: 2px;">{{ app.user.pseudo|default('Joueur') }}</div>
            <div class="text-warning fw-bold fs-3"><span id="user-jetons">{{ app.user.jetons|default(0) }}</span> <small class="text-white-50" style="font-size: 0.5em;">JETONS</small></div>
        </div>
        <a href="/depotretrait" class="btn-add-funds shadow-lg"><span>+</span></a>
    </div>

    <div class="container text-center">
        {# --- TITRE --- #}
        <div class="mb-5">
            <h1 class="display-1 fw-bold text-uppercase mb-2 text-warning main-title">Le 777</h1>
            <div class="d-flex justify-content-center align-items-center gap-3">
                <div class="divider-gold"></div>
                <button class="btn-info-circle-gold" data-bs-toggle="modal" data-bs-target="#rulesModal">?</button>
                <div class="divider-gold-reverse"></div>
            </div>
        </div>

        {# MACHINE À SOUS AVEC MANIVELLE#}
        <div class="row justify-content-center align-items-center mb-5">
            
            <div class="col-auto d-flex align-items-end position-relative">
                
                {# La machine elle-même #}
                <div class="neon-card gold-glow shadow-lg p-3 z-2">
                    <div class="card-inner p-4 d-flex gap-4" style="border-radius: 15px;">
                        <div class="reel"><span class="reel-number" id="reel-0">7</span></div>
                        <div class="reel"><span class="reel-number" id="reel-1">7</span></div>
                        <div class="reel"><span class="reel-number" id="reel-2">7</span></div>
                    </div>
                </div>

                {# La manivelle (fixée sur le côté droit de la machine) #}
                <div class="lever-container ms-2">
                    <div class="lever-base"></div>
                    <div id="lever-arm" class="lever-arm">
                        <div class="lever-handle"></div>
                    </div>
                </div>

            </div>
        </div>

        {# --- PANEL DE MISE --- #}
        <div class="row justify-content-center">
            <div class="col-12 col-md-6 col-lg-4">
                <div class="bet-card-gold">
                    <div class="bet-inner p-4">
                        <label class="form-label small text-uppercase fw-bold text-warning mb-3" style="letter-spacing: 2px;">Mise en jeu</label>
                        <div class="input-group mb-4">
                            <input type="number" id="bet-input" class="form-control bet-input-gold" value="10" min="1">
                            <span class="input-group-text bg-dark text-white-50 border-0 px-3">JETONS</span>
                        </div>

                        {# BOÎTE DE RÉSULTAT INTÉGRÉE #}
                        <div id="result-box" class="mb-4 p-3 rounded d-none transition-all">
                            <h5 id="result-message" class="mb-0 fw-bold text-uppercase" style="letter-spacing: 1px;"></h5>
                        </div>

                        {# Le bouton textuel reste en sécurité si la manivelle est cachée sur mobile #}
                        <button id="btn-play-text" class="btn-play gold w-100 mb-3 d-md-none">TIRER LA MANIVELLE</button>
                        
                        <p class="text-white-50 small mb-3 d-none d-md-block"><i class="bi bi-hand-index-thumb"></i> Cliquez sur la manivelle pour jouer</p>

                        <a href="/menu" class="exit-btn d-block mt-2">QUITTER LA MACHINE</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# RÈGLES#}
<div class="modal fade" id="rulesModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark border-warning shadow-lg">
            <div class="modal-header border-0">
                <h5 class="modal-title text-warning fw-bold text-uppercase">Table des gains</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center py-4 text-white">
                <p class="text-white-50 small mb-4">La machine tire 3 chiffres entre 1 et 9.</p>
                <div class="d-flex justify-content-between border-bottom border-secondary p-2">
                    <span>🎰 7 - 7 - 7 (Jackpot Absolu)</span> <strong class="text-warning">x100</strong>
                </div>
                <div class="d-flex justify-content-between border-bottom border-secondary p-2">
                    <span>3 Chiffres Identiques</span> <strong class="text-warning">x50</strong>
                </div>
                <div class="d-flex justify-content-between border-bottom border-secondary p-2">
                    <span>2 Chiffres Identiques</span> <strong class="text-info">x5</strong>
                </div>
                <div class="d-flex justify-content-between p-2">
                    <span>Un seul 7 affiché</span> <strong class="text-success">Remboursé (x1)</strong>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('turbo:load', () => {
    // Éléments
    const leverArm = document.getElementById('lever-arm');
    const leverContainer = document.querySelector('.lever-container');
    const btnPlayText = document.getElementById('btn-play-text'); // Fallback mobile
    const betInput = document.getElementById('bet-input');
    const jetonsDisplay = document.getElementById('user-jetons');
    const resultBox = document.getElementById('result-box');
    const resultMessage = document.getElementById('result-message');
    
    const reels = [
        document.getElementById('reel-0'),
        document.getElementById('reel-1'),
        document.getElementById('reel-2')
    ];

    let isPlaying = false;

    // Fonction de déclenchement du jeu
    async function play() {
        if (isPlaying) return;
        
        const mise = parseInt(betInput.value);

        if (isNaN(mise) || mise <= 0) {
            showResult("Mise invalide", false);
            return;
        }

        // Bloquer les interactions
        isPlaying = true;
        if(btnPlayText) btnPlayText.disabled = true;
        leverArm.style.pointerEvents = 'none';
        
        // Animation CSS de la manivelle
        leverArm.classList.add('pulled');
        setTimeout(() => {
            leverArm.classList.remove('pulled');
        }, 500); // La manivelle remonte après 0.5s

        resultBox.classList.add('d-none');
        reels.forEach(reel => reel.classList.add('text-muted', 'spinning'));

        try {
            const response = await fetch('{{ path('app_jeu777_play') }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ mise: mise })
            });

            const data = await response.json();
            if (data.error) {
                showResult(data.error, false);
                resetPlayState();
                return;
            }

            // Animation des rouleaux
            let count = 0;
            const spinInterval = setInterval(() => {
                reels.forEach(reel => reel.innerText = Math.floor(Math.random() * 9) + 1);
                
                if (++count > 20) {
                    clearInterval(spinInterval);
                    
                    stopReel(0, data.tirage[0], 0);
                    stopReel(1, data.tirage[1], 400); 
                    stopReel(2, data.tirage[2], 800); 
                    
                    setTimeout(() => {
                        jetonsDisplay.innerText = data.nouveauSolde;
                        resetPlayState();

                        if (data.gain > 0) {
                            if (data.isJackpot777) {
                                showResult(`🎰 JACKPOT 777 !!! +${data.gain} 🎰`, true);
                                reels.forEach(r => r.style.color = "#ffc107");
                            } else if (data.gain === mise * 50) {
                                showResult(`BRELAN MAGIQUE ! +${data.gain}`, true);
                            } else if (data.gain === mise * 5) {
                                showResult(`Paire trouvée ! +${data.gain}`, true);
                            } else {
                                showResult(`Sauvé par le 7 ! Remboursé.`, true);
                            }
                        } else {
                            showResult("Perdu... Tirez encore !", false);
                        }
                    }, 1200);
                }
            }, 50);

        } catch (e) {
            console.error(e);
            showResult("Erreur de communication", false);
            resetPlayState();
        }
    }

    // Gestionnaires d'événements
    leverArm.addEventListener('click', play);
    if(btnPlayText) btnPlayText.addEventListener('click', play);

    // Fonctions utilitaires
    function resetPlayState() {
        isPlaying = false;
        if(btnPlayText) btnPlayText.disabled = false;
        leverArm.style.pointerEvents = 'auto';
        reels.forEach(reel => reel.classList.remove('text-muted', 'spinning'));
    }

    function stopReel(index, finalValue, delay) {
        setTimeout(() => {
            reels[index].innerText = finalValue;
            reels[index].classList.remove('text-muted', 'spinning');
            reels[index].style.transform = "scale(1.3)";
            setTimeout(() => reels[index].style.transform = "scale(1)", 200);
        }, delay);
    }

    function showResult(message, isWin) {
        resultBox.classList.remove('d-none', 'win-glow-gold', 'lose-glow-dark', 'text-warning', 'text-danger');
        resultMessage.innerText = message;
        
        if (isWin) {
            resultBox.classList.add('win-glow-gold', 'text-warning');
        } else {
            resultBox.classList.add('lose-glow-dark', 'text-danger');
        }
        if(!isWin) reels.forEach(r => r.style.color = "white");
    }
});
</script>

<style>
    .main-title { text-shadow: 0px 0px 30px rgba(255, 140, 0, 0.6); font-size: calc(2.5rem + 4vw); }
    .divider-gold { height: 1px; width: 80px; background: linear-gradient(to right, transparent, #ff8c00); }
    .divider-gold-reverse { height: 1px; width: 80px; background: linear-gradient(to left, transparent, #ff8c00); }

    .reel {
        background: linear-gradient(145deg, #1a1a1a, #000);
        width: 100px; height: 140px; border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        border: 2px solid rgba(255, 140, 0, 0.4);
        box-shadow: inset 0 0 30px rgba(0,0,0,0.9);
        transition: transform 0.2s ease, color 0.3s ease;
    }
    .reel-number { font-size: 4rem; font-weight: 900; color: white; text-shadow: 0 0 15px rgba(255, 255, 255, 0.2); }
    .spinning { filter: blur(2px); opacity: 0.8; }

    .neon-card.gold-glow {
        background: rgba(255, 140, 0, 0.05);
        border: 1px solid rgba(255, 140, 0, 0.3);
        border-radius: 20px; padding: 2px;
        box-shadow: 0 0 30px rgba(255, 140, 0, 0.15);
    }
    .card-inner { background: #0a0a0a; border-radius: 18px; }

    .bet-card-gold {
        background: rgba(255, 140, 0, 0.05);
        border: 1px solid rgba(255, 140, 0, 0.2);
        border-radius: 20px; padding: 2px;
    }
    .bet-inner { background: #0a0a0a; border-radius: 18px; }

    .bet-input-gold {
        background: transparent !important; border: none !important;
        border-bottom: 2px solid #ff8c00 !important; color: #ffc107 !important;
        font-weight: bold; font-size: 1.5rem; text-align: center;
    }
    .bet-input-gold:focus { box-shadow: none; border-color: white !important; }

    .btn-play.gold {
        background: transparent; color: #ff8c00; border: 2px solid #ff8c00;
        border-radius: 50px; padding: 15px; font-weight: 900; letter-spacing: 2px;
        transition: 0.3s;
    }
    .btn-play.gold:hover:not(:disabled) {
        background: #ff8c00; color: black; box-shadow: 0 0 20px #ff8c00;
    }
    .btn-play:disabled { opacity: 0.5; cursor: not-allowed; filter: grayscale(1); border-color: gray; color: gray;}

    .win-glow-gold { background: rgba(255, 193, 7, 0.1); border: 1px solid #ffc107; box-shadow: 0 0 15px rgba(255, 193, 7, 0.4); }
    .lose-glow-dark { background: rgba(220, 53, 69, 0.1); border: 1px solid #dc3545; box-shadow: 0 0 15px rgba(220, 53, 69, 0.2); }
    .transition-all { transition: all 0.3s ease; }

    .btn-info-circle-gold {
        background: transparent; border: 1px solid #ff8c00; color: #ff8c00;
        width: 40px; height: 40px; border-radius: 50%; transition: 0.3s;
    }
    .btn-info-circle-gold:hover { background: #ff8c00; color: black; box-shadow: 0 0 15px #ff8c00;}

    .exit-btn { color: #6c757d; text-decoration: none; font-size: 0.9rem; transition: 0.3s; }
    .exit-btn:hover { color: white; text-decoration: underline; }
    
    .btn-add-funds {
        background: #ffc107; color: black; width: 45px; height: 45px;
        border-radius: 50%; display: flex; align-items: center; justify-content: center;
        text-decoration: none; font-size: 1.5rem; font-weight: bold; transition: 0.3s;
    }
    .btn-add-funds:hover { transform: scale(1.1); background: white; }
    .text-muted { opacity: 0.5; }

    /* --- STYLES DE LA MANIVELLE --- */
    .lever-container {
        position: relative;
        height: 140px; /* Aligné avec la hauteur des rouleaux */
        width: 40px;
        display: none; /* Caché sur petits écrans, affiché via media query */
    }

    @media (min-width: 768px) {
        .lever-container {
            display: block;
        }
    }

    .lever-base {
        position: absolute;
        bottom: 20px;
        left: 0;
        width: 30px;
        height: 50px;
        background: linear-gradient(to right, #444, #888, #444);
        border-radius: 5px;
        border: 2px solid #222;
        box-shadow: 2px 2px 5px rgba(0,0,0,0.5);
        z-index: 1;
    }

    .lever-arm {
        position: absolute;
        bottom: 45px;
        left: 10px;
        width: 10px;
        height: 100px;
        background: linear-gradient(to right, #ccc, #fff, #ccc);
        border-radius: 5px;
        transform-origin: bottom center;
        transition: transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        cursor: pointer;
        z-index: 2;
    }

    /* La poignée rouge en haut de la manivelle */
    .lever-handle {
        position: absolute;
        top: -15px;
        left: -10px;
        width: 30px;
        height: 30px;
        background: radial-gradient(circle at 30% 30%, #ff4d4d, #b30000);
        border-radius: 50%;
        box-shadow: inset -2px -2px 5px rgba(0,0,0,0.5), 2px 2px 5px rgba(0,0,0,0.5);
        transition: background 0.2s ease;
    }

    .lever-arm:hover .lever-handle {
        background: radial-gradient(circle at 30% 30%, #ff6666, #cc0000);
        box-shadow: 0 0 10px #ff4d4d;
    }

    /* Animation CSS déclenchée par le JS */
    .lever-arm.pulled {
        transform: rotateX(180deg) scaleY(0.5); /* Simule l'effet 3D de la manivelle tirée vers le bas */
    }
</style>
{% endblock %}