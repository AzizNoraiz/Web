{% extends 'base.html.twig' %}

{% block title %}Casino Royal | La Banque{% endblock %}

{% block body %}
<div class="bg-casino min-vh-100 py-5 position-relative d-flex align-items-center" style="background: radial-gradient(circle, #0a0a0a 0%, #000000 100%); overflow: hidden;">

    {# --- HEADER FORTUNE --- #}
    <div class="position-absolute top-0 end-0 p-4 text-end" style="z-index: 1000;">
        <div class="text-white-50 fw-bold text-uppercase small" style="letter-spacing: 2px;">Votre Fortune</div>
        <div class="text-warning fw-bold fs-2" style="text-shadow: 0 0 15px rgba(255, 140, 0, 0.4);">
            5 000 <small class="text-white-50" style="font-size: 0.5em;">JETONS</small>
        </div>
    </div>

    <div class="container">
        {# --- TITRE --- #}
        <div class="text-center mb-5">
            <h1 class="display-1 fw-bold text-uppercase mb-2 text-warning main-title-bank">
                La Banque
            </h1>
            <div class="d-flex justify-content-center align-items-center gap-3">
                <div class="divider-gold"></div>
                <p class="text-white-50 text-uppercase mb-0 fw-light" style="letter-spacing: 5px; font-size: 0.8rem;">Transactions Sécurisées</p>
                <div class="divider-gold-reverse"></div>
            </div>
        </div>

        <div class="row justify-content-center g-5">
            {# --- SECTION DÉPÔT (VERT) --- #}
            <div class="col-12 col-lg-5">
                <div class="neon-card green-glow h-100">
                    <div class="card-inner p-4 text-center">
                        <div class="bank-icon text-success mb-3">
                            <i class="bi bi-shield-lock-fill"></i>
                        </div>
                        <h2 class="h3 text-white fw-bold text-uppercase mb-3">Dépôt</h2>
                        <p class="text-white-50 small mb-4">Alimentez votre compte pour accéder aux tables VIP.</p>
                        
                        <form action="/depot" method="POST">
                            <div class="mb-4 text-start">
                                <label class="form-label small text-uppercase fw-bold text-success" style="letter-spacing: 1px;">Montant à déposer (€)</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-dark border-0 text-success">€</span>
                                    <input type="number" class="form-control bank-input border-success-subtle" placeholder="Ex: 50">
                                </div>
                            </div>
                            <button type="submit" class="btn-bank green w-100">
                                ACHETER DES JETONS
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            {# --- SECTION RETRAIT (ROUGE) --- #}
            <div class="col-12 col-lg-5">
                <div class="neon-card red-glow h-100">
                    <div class="card-inner p-4 text-center">
                        <div class="bank-icon text-danger mb-3">
                            <i class="bi bi-cash-stack"></i>
                        </div>
                        <h2 class="h3 text-white fw-bold text-uppercase mb-3">Retrait</h2>
                        <p class="text-white-50 small mb-4">Convertissez vos jetons en argent réel instantanément.</p>
                        
                        <form action="/retrait" method="POST">
                            <div class="mb-4 text-start">
                                <label class="form-label small text-uppercase fw-bold text-danger" style="letter-spacing: 1px;">Jetons à retirer</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-dark border-0 text-danger">#</span>
                                    <input type="number" class="form-control bank-input border-danger-subtle" placeholder="Ex: 1000">
                                </div>
                            </div>
                            <button type="submit" class="btn-bank red w-100">
                                ENCAISSER LES GAINS
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        {# --- PIED DE PAGE --- #}
        <div class="text-center mt-5">
            <a href="/menu" class="btn-outline-exit">
                <i class="bi bi-chevron-left me-2"></i>RETOUR AU SALON
            </a>
        </div>
    </div>
</div>

<style>
    /* TITRE */
    .main-title-bank {
        text-shadow: 0px 0px 30px rgba(255, 193, 7, 0.4);
        font-size: calc(2.5rem + 3vw);
        letter-spacing: -2px;
    }
    .divider-gold { height: 1px; width: 60px; background: linear-gradient(to right, transparent, #ffc107); }
    .divider-gold-reverse { height: 1px; width: 60px; background: linear-gradient(to left, transparent, #ffc107); }

    /* STRUCTURE NÉON (Reprise du menu) */
    .neon-card {
        position: relative;
        background: rgba(0, 0, 0, 0.8);
        border-radius: 25px;
        padding: 2px;
        overflow: hidden;
    }
    .neon-card::before {
        content: "";
        position: absolute;
        top: -50%; left: -50%; width: 200%; height: 200%;
        animation: rotate-neon 4s linear infinite;
        z-index: 1;
    }
    .green-glow::before { background: conic-gradient(#198754, transparent, #20c997, transparent, #198754); }
    .red-glow::before { background: conic-gradient(#dc3545, transparent, #ff4500, transparent, #dc3545); }

    @keyframes rotate-neon { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

    .card-inner {
        position: relative;
        background: #0a0a0a;
        border-radius: 23px;
        z-index: 2;
        height: 100%;
        backdrop-filter: blur(10px);
    }

    /* ICONS & INPUTS */
    .bank-icon { font-size: 3.5rem; filter: drop-shadow(0 0 10px currentColor); }
    
    .bank-input {
        background: #151515 !important;
        border: 1px solid rgba(255,255,255,0.1) !important;
        color: white !important;
        padding: 12px 15px !important;
        font-weight: bold;
    }
    .bank-input:focus {
        box-shadow: 0 0 15px rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 255, 255, 0.3) !important;
    }

    /* BOUTONS */
    .btn-bank {
        padding: 15px;
        border-radius: 50px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        border: none;
        color: white;
        transition: 0.3s;
    }
    .btn-bank.green { background: linear-gradient(45deg, #198754, #20c997); box-shadow: 0 5px 15px rgba(25, 135, 84, 0.3); }
    .btn-bank.red { background: linear-gradient(45deg, #dc3545, #ff4500); box-shadow: 0 5px 15px rgba(220, 53, 69, 0.3); }
    
    .btn-bank:hover {
        transform: translateY(-3px);
        filter: brightness(1.2);
        box-shadow: 0 0 20px currentColor;
    }

    .btn-outline-exit {
        text-decoration: none;
        color: rgba(255, 255, 255, 0.5);
        border: 1px solid rgba(255, 255, 255, 0.2);
        padding: 10px 30px;
        border-radius: 50px;
        font-weight: bold;
        transition: 0.3s;
    }
    .btn-outline-exit:hover {
        color: #ffc107;
        border-color: #ffc107;
        background: rgba(255, 193, 7, 0.05);
    }
</style>
{% endblock %}