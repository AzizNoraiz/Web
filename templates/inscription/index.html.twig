{% extends 'base.html.twig' %}

{% block title %}Casino Royal | Inscription{% endblock %}

{% block body %}
<div class="bg-casino min-vh-100 py-5 d-flex align-items-center">
    <div class="container">
        {# --- TITRE PRINCIPAL --- #}
        <div class="text-center mb-5">
            <h1 class="display-1 fw-bold text-uppercase mb-2 text-warning"
                style="text-shadow: 0px 0px 30px rgba(255, 0, 0, 0.8); letter-spacing: -2px;">
                Casino Royal
            </h1>
            <p class="text-white-50 text-uppercase fw-light" style="letter-spacing: 5px; font-size: 0.9rem;">Devenir Membre de l'Élite</p>
        </div>

        <div class="row justify-content-center">
            <div class="col-12 col-lg-8 col-xl-7">
                {# --- UTILISATION DE LA NEON-CARD CENTRALISÉE --- #}
                <div class="neon-card gold-glow shadow-lg">
                    <div class="card-inner p-4 p-md-5">
                        
                        <h2 class="h4 text-white text-center mb-5 fw-bold text-uppercase" style="letter-spacing: 2px;">
                            Ouverture de Compte
                        </h2>

                        <form action="/inscription" method="POST">
                            {# Identifiant #}
                            <div class="mb-4">
                                <label class="form-label small text-uppercase fw-bold text-warning">Nom d'utilisateur</label>
                                <input type="text" class="form-control bank-input border-warning-subtle" placeholder="Pseudo Gold">
                            </div>

                            {# Nom & Prénom #}
                            <div class="row">
                                <div class="col-md-6 mb-4">
                                    <label class="form-label small text-uppercase fw-bold text-warning">Nom</label>
                                    <input type="text" class="form-control bank-input border-warning-subtle" placeholder="Nom">
                                </div>
                                <div class="col-md-6 mb-4">
                                    <label class="form-label small text-uppercase fw-bold text-warning">Prénom</label>
                                    <input type="text" class="form-control bank-input border-warning-subtle" placeholder="Prénom">
                                </div>
                            </div>

                            {# Mail & Tel #}
                            <div class="row">
                                <div class="col-md-7 mb-4">
                                    <label class="form-label small text-uppercase fw-bold text-warning">Adresse Mail</label>
                                    <input type="email" class="form-control bank-input border-warning-subtle" placeholder="exemple@mail.com">
                                </div>
                                <div class="col-md-5 mb-4">
                                    <label class="form-label small text-uppercase fw-bold text-warning">Téléphone</label>
                                    <input type="tel" class="form-control bank-input border-warning-subtle" placeholder="06 ...">
                                </div>
                            </div>

                            {# Password #}
                            <div class="mb-5">
                                <label class="form-label small text-uppercase fw-bold text-warning">Mot de passe</label>
                                <input type="password" class="form-control bank-input border-warning-subtle" placeholder="••••••••">
                            </div>

                            {# Bouton Valider #}
                            <div class="text-center">
                                <button type="submit" class="btn-play gold w-100 py-3 shadow-lg">
                                    CRÉER MON COMPTE ROYAL
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                {# --- LIEN RETOUR --- #}
                <div class="text-center mt-4">
                    <a href="/home" class="exit-btn">← RETOUR À L'ACCUEIL</a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* On réutilise les styles d'inputs définis pour la banque pour garder une cohérence */
    .bank-input {
        background: #151515 !important;
        border: none !important;
        border-bottom: 2px solid rgba(255, 140, 0, 0.3) !important;
        color: white !important;
        padding: 12px 15px !important;
        transition: 0.3s;
    }
    .bank-input:focus {
        border-bottom-color: #ff8c00 !important;
        box-shadow: 0 5px 15px rgba(255, 140, 0, 0.1);
    }
    
    /* Style spécifique pour les calendriers (date) sur Chrome/Safari */
    input[type="date"]::-webkit-calendar-picker-indicator {
        filter: invert(1) sepia(100%) saturate(1000%) hue-rotate(10deg);
        cursor: pointer;
    }
</style>
{% endblock %}