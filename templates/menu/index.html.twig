{% extends 'base.html.twig' %}

{% block title %}Casino Royal | Le Salon d'Élite{% endblock %}

{% block body %}
<div class="bg-casino min-vh-100 py-5 d-flex align-items-center">

    {# --- BARRE UTILISATEUR (TOP) --- #}
    <div class="position-absolute top-0 end-0 p-4 d-flex align-items-center gap-3" style="z-index: 1000;">
        <div class="text-end">
            <div class="text-white-50 fw-bold text-uppercase small" style="letter-spacing: 2px;">
                {{ app.user.username|default('Membre Gold') }}
            </div>
            <div class="text-warning fw-bold fs-3" style="text-shadow: 0 0 10px rgba(255, 140, 0, 0.5);">
                5 000 <small class="text-white-50" style="font-size: 0.5em;">JETONS</small>
            </div>
        </div>
        <a href="/depotretrait" class="btn-add-funds shadow-lg">
            <span>+</span>
        </a>
    </div>

    <div class="container">
        {# --- TITRE PRINCIPAL --- #}
        <div class="text-center mb-5">
            <h1 class="display-1 fw-bold text-uppercase mb-2 text-warning"
                style="text-shadow: 0px 0px 30px rgba(255, 0, 0, 0.8); letter-spacing: -2px;">
                Casino Royal
            </h1>
            <div class="d-flex justify-content-center align-items-center gap-3">
                <div style="height: 1px; width: 80px; background: linear-gradient(to right, transparent, #ff8c00);"></div>
                <p class="text-white-50 text-uppercase mb-0 fw-light" style="letter-spacing: 8px; font-size: 0.9rem;">Salon Privé</p>
                <div style="height: 1px; width: 80px; background: linear-gradient(to left, transparent, #ff8c00);"></div>
            </div>
        </div>

        {# --- GRILLE DES JEUX --- #}
        <div class="row g-5 justify-content-center mt-2">
            
            {# JEU 1 : 777 #}
            <div class="col-12 col-md-4">
                <div class="neon-card gold-glow">
                    <div class="card-inner text-center">
                        <div class="game-display text-warning">777</div>
                        <h2 class="h4 text-white fw-bold text-uppercase mb-3">Le Jackpot</h2>
                        <p class="text-white-50 small mb-4">La machine mythique. Aligne les sept et décroche l'or.</p>
                        <a href="/jeu777" class="btn-play gold">ENTRER</a>
                    </div>
                </div>
            </div>

            {# JEU 2 : DOUBLE MISE #}
            <div class="col-12 col-md-4">
                <div class="neon-card red-glow">
                    <div class="card-inner text-center">
                        <div class="game-display text-danger">x2</div>
                        <h2 class="h4 text-white fw-bold text-uppercase mb-3">Double Mise</h2>
                        <p class="text-white-50 small mb-4">Pile ou face moderne. La chance sourit aux audacieux.</p>
                        <a href="/jeuquitteoudouble" class="btn-play red">ENTRER</a>
                    </div>
                </div>
            </div>

            {# JEU 3 : BINGO #}
            <div class="col-12 col-md-4">
                <div class="neon-card blue-glow">
                    <div class="card-inner text-center">
                        <div class="game-display text-info">B</div>
                        <h2 class="h4 text-white fw-bold text-uppercase mb-3">Bingo Royal</h2>
                        <p class="text-white-50 small mb-4">Le tirage de la cour. Choisis tes chiffres, attend le destin.</p>
                        <a href="/jeubingo" class="btn-play blue">ENTRER</a>
                    </div>
                </div>
            </div>

        </div>

        {# --- BOUTON QUITTER --- #}
        <div class="text-center mt-5 pt-4">
            <a href="/home" class="exit-btn">QUITTER LE SALON</a>
        </div>
    </div>
</div>

<style>
    /* On ne garde ici que les styles spécifiques à cette page (icones géantes) */
    .game-display {
        font-size: 5rem;
        font-weight: 900;
        margin-bottom: 10px;
        transition: 0.3s;
    }
    
    .neon-card:hover .game-display {
        transform: scale(1.1);
        filter: brightness(1.5) drop-shadow(0 0 10px currentColor);
    }
</style>
{% endblock %}