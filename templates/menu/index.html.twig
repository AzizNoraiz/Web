{% extends 'base.html.twig' %}

{% block title %}Casino Royal | Le Salon d'Élite{% endblock %}

{% block body %}
<div class="bg-casino min-vh-100 py-5 d-flex flex-column align-items-center justify-content-center">

    {# --- BARRE UTILISATEUR (TOP) --- #}
    <div class="position-absolute top-0 end-0 p-4 d-flex align-items-center gap-3" style="z-index: 1000;">
        <div class="text-end">
            <div class="text-white-50 fw-bold text-uppercase small" style="letter-spacing: 2px;">
                {# 1. On utilise "pseudo" car c'est le nom dans ton entité Personne #}
                {{ app.user ? app.user.pseudo : 'Membre Gold' }}
            </div>
            <div class="text-warning fw-bold fs-3" style="text-shadow: 0 0 10px rgba(255, 140, 0, 0.5);">
                {# 2. On affiche le VRAI solde de jetons. Le filtre number_format ajoute un espace pour faire "5 000" au lieu de "5000" #}
                {{ app.user ? app.user.jetons|number_format(0, '', ' ') : '0' }} 
                <small class="text-white-50" style="font-size: 0.5em;">JETONS</small>
            </div>
        </div>
        <a href="{{ path('app_depot_retrait') }}" class="btn-add-funds shadow-lg">
            <span>+</span>
        </a>
    </div>

    <div class="container mt-4">
        {# --- TITRE PRINCIPAL --- #}
        <div class="text-center mb-5">
            <h1 class="display-1 fw-bold text-uppercase mb-2 text-warning"
                style="text-shadow: 0px 0px 30px rgba(255, 0, 0, 0.8); letter-spacing: -2px;">
                Casino Royal
            </h1>
            <div class="d-flex justify-content-center align-items-center gap-3">
                <div style="height: 1px; width: 80px; background: linear-gradient(to right, transparent, #ff8c00);"></div>
                <p class="text-white-50 text-uppercase mb-0 fw-light" style="letter-spacing: 8px; font-size: 0.9rem;">Salon Privé</p>
                <div style="height: 1px; width: 80px; background: linear-gradient(to left, transparent, #ff8c00);"></div>
            </div>
        </div>

        {# --- GRILLE DES JEUX --- #}
        <div class="row g-5 justify-content-center mt-2 mb-5">
            
            {# JEU 1 : 777 #}
            <div class="col-12 col-md-4">
                <div class="neon-card gold-glow h-100">
                    <div class="card-inner text-center d-flex flex-column h-100">
                        <div class="game-display text-warning mt-3">777</div>
                        <h2 class="h4 text-white fw-bold text-uppercase mb-3 mt-auto">Le Jackpot</h2>
                        <p class="text-white-50 small mb-4">La machine mythique. Aligne les sept et décroche l'or.</p>
                        <a href="{{ path('app_jeu777') }}" class="btn-play gold mt-auto" >ENTRER</a>
                    </div>
                </div>
            </div>

            {# JEU 2 : DOUBLE MISE #}
            <div class="col-12 col-md-4">
                <div class="neon-card red-glow h-100">
                    <div class="card-inner text-center d-flex flex-column h-100">
                        <div class="game-display text-danger mt-3">x2</div>
                        <h2 class="h4 text-white fw-bold text-uppercase mb-3 mt-auto">Double Mise</h2>
                        <p class="text-white-50 small mb-4">Pile ou face moderne</p>
                        <a href="{{ path('app_quitte_ou_double') }}" class="btn-play red mt-auto" >ENTRER</a>
                    </div>
                </div>
            </div>

            {# JEU 3 : BINGO #}
            <div class="col-12 col-md-4">
                <div class="neon-card blue-glow h-100">
                    <div class="card-inner text-center d-flex flex-column h-100">
                        <div class="game-display text-info mt-3">B</div>
                        <h2 class="h4 text-white fw-bold text-uppercase mb-3 mt-auto">Bingo Royal</h2>
                        <p class="text-white-50 small mb-4">Le tirage de la cour. Choisis tes chiffres, attend le destin.</p>
                        <a href="{{ path('app_jeubingo') }}" class="btn-play blue mt-auto"  >ENTRER</a>
                    </div>
                </div>
            </div>

        </div>

        {# --- NOUVEAU BOUTON : HALL OF FAME --- #}
        <div class="row justify-content-center mt-4">
            <div class="col-12 col-md-6 col-lg-4 text-center">
                <a href="{{ path('app_classement') }}" class="btn-play blue py-3 fs-5 shadow-lg w-100 d-block" style="border-color: #0dcaf0; color: #0dcaf0; background: rgba(13, 202, 240, 0.05);">
                    <i class="bi bi-trophy me-2"></i> HALL OF FAME
                </a>
            </div>
        </div>

        {# --- BOUTON QUITTER --- #}
        <div class="text-center mt-5 pt-4">
            <a href="/home" class="exit-btn">QUITTER LE SALON</a>
        </div>
    </div>
</div>

<style>
    /* On ne garde ici que les styles spécifiques à cette page (icones géantes) */
    .game-display {
        font-size: 5rem;
        font-weight: 900;
        margin-bottom: 10px;
        transition: 0.3s;
    }
    
    .neon-card:hover .game-display {
        transform: scale(1.1);
        filter: brightness(1.5) drop-shadow(0 0 10px currentColor);
    }
    
    /* Bouton Bleu (pour correspondre au style du Bingo et du bouton classement) */
    .btn-play.blue {
        display: inline-block; text-decoration: none;
        background: transparent; color: #0dcaf0; border: 2px solid #0dcaf0;
        border-radius: 50px; padding: 10px 20px; font-weight: 900; letter-spacing: 2px;
        transition: 0.3s;
    }
    .btn-play.blue:hover { background: #0dcaf0 !important; color: #000 !important; box-shadow: 0 0 20px #0dcaf0; }
</style>
{% endblock %}