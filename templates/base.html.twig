<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>
            {% block title %}Casino Royal{% endblock %}
        </title>

        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css">

        <style>
            /* --- FOND ET TYPO DE BASE --- */
            body {
                background-color: #000;
                color: white;
                font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
                margin: 0;
                overflow-x: hidden;
            }

            .bg-casino {
                background: radial-gradient(circle, #1a1a1a 0%, #000000 100%);
                min-height: 100vh;
                position: relative;
            }

            /* --- COMPOSANTS RÉUTILISABLES (NÉONS) --- */
            .neon-card {
                position: relative;
                background: rgba(0, 0, 0, 0.8);
                border-radius: 25px;
                padding: 2px;
                overflow: hidden;
                height: 100%;
                transition: 0.3s ease-in-out;
            }

            .neon-card::before {
                content: "";
                position: absolute;
                top: -50%;
                left: -50%;
                width: 200%;
                height: 200%;
                animation: rotate-neon 4s linear infinite;
                z-index: 1;
            }

            /* Couleurs des Néons */
            .gold-glow::before { background: conic-gradient(#ff8c00, transparent, #ffc107, transparent, #ff8c00); }
            .red-glow::before { background: conic-gradient(#ff4500, transparent, #ff0000, transparent, #ff4500); }
            .blue-glow::before { background: conic-gradient(#0dcaf0, transparent, #007bff, transparent, #0dcaf0); }
            .green-glow::before { background: conic-gradient(#198754, transparent, #20c997, transparent, #198754); }

            @keyframes rotate-neon {
                from { transform: rotate(0deg); }
                to { transform: rotate(360deg); }
            }

            .card-inner {
                position: relative;
                background: #0a0a0a;
                border-radius: 23px;
                padding: 30px 20px;
                z-index: 2;
                height: 100%;
                backdrop-filter: blur(10px);
            }

            /* --- BOUTONS --- */
            .btn-play, .btn-bank {
                display: block;
                text-decoration: none;
                font-weight: 800;
                padding: 12px 25px;
                border-radius: 50px;
                transition: 0.3s;
                color: white;
                border: none;
                text-align: center;
                text-transform: uppercase;
            }
            .btn-play.gold, .btn-bank.gold { background: #ff8c00; box-shadow: 0 5px 15px rgba(255, 140, 0, 0.3); }
            .btn-play.red, .btn-bank.red { background: #ff4500; box-shadow: 0 5px 15px rgba(255, 69, 0, 0.3); }
            .btn-play.blue, .btn-bank.blue { background: #0dcaf0; color: black; box-shadow: 0 5px 15px rgba(13, 202, 240, 0.3); }
            .btn-play.green, .btn-bank.green { background: #198754; box-shadow: 0 5px 15px rgba(25, 135, 84, 0.3); }

            .btn-play:hover, .btn-bank:hover {
                transform: translateY(-3px);
                filter: brightness(1.2);
                box-shadow: 0 0 20px currentColor;
            }

            /* --- TOP BAR & ADD FUNDS --- */
            .btn-add-funds {
                background: linear-gradient(45deg, #ff4500, #ff8c00);
                width: 45px;
                height: 45px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                color: #212529; /* Correction ici */
                text-decoration: none;
                font-weight: bold;
                font-size: 1.5rem;
                transition: 0.3s;
            }
            .btn-add-funds:hover {
                transform: scale(1.1) rotate(90deg);
                color: #212529; /* Correction ici */
            }

            /* --- LIENS DE SORTIE --- */
            .exit-btn {
                color: rgba(255, 255, 255, 0.5);
                text-decoration: none;
                font-size: 0.8rem;
                letter-spacing: 1px;
                transition: 0.4s;
            }
            .exit-btn:hover {
                color: #212529 !important; /* Correction ici */
                letter-spacing: 2px;
            }

            /* --- CHATBOT DESIGN --- */
            .chatbot-btn {
                position: fixed;
                bottom: 30px;
                right: 30px;
                border-radius: 50px;
                padding: 15px 25px;
                font-weight: bold;
                z-index: 1000;
            }
            .chat-widget {
                display: none; 
                position: fixed;
                bottom: 90px;
                right: 30px;
                width: 350px;
                height: 450px;
                background: #1a1a1a;
                border: 2px solid #ff8c00;
                border-radius: 10px;
                z-index: 1000;
                flex-direction: column;
            }
            .chat-messages {
                flex-grow: 1;
                overflow-y: auto;
            }
        </style>

        {% block stylesheets %}{% endblock %}

        {% block javascripts %}
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
            {% block importmap %}
                {{ importmap('app') }}
            {% endblock %}
        {% endblock %}
    </head>
    <body>
        
        {% block body %}{% endblock %}

        {# --- BOUTON FLOTTANT CHATBOT --- #}
        <div id="chat-widget" class="chat-widget shadow-lg">
            <div class="chat-header bg-dark text-warning p-3 d-flex justify-content-between align-items-center">
                <h5 class="m-0 fw-bold">
                    <i class="bi bi-robot"></i> Croupier Virtuel
                </h5>
                <button id="close-chat" class="btn btn-sm btn-outline-warning">X</button>
            </div>

            <div id="chat-messages" class="chat-messages p-3 text-white" style="background: #151515;">
                <div class="message bot-message mb-3">
                    <span class="text-warning fw-bold">Hôte ></span>
                    Bonjour ! Comment puis-je vous aider dans le Casino Royal aujourd'hui ?
                </div>
            </div>

            <div class="chat-input p-2 bg-dark d-flex">
                <input type="text" id="user-input" class="form-control bank-input border-warning-subtle text-dark me-2" placeholder="Posez une question...">
                <button id="send-btn" class="btn btn-warning">Envoyer</button>
            </div>
        </div>

        <button id="chatbot-btn" class="btn btn-warning shadow-lg chatbot-btn">
            💬 Aide
        </button>

        {# --- LE CERVEAU DU CHATBOT (JAVASCRIPT) --- #}
        <script>
            document.addEventListener('turbo:load', function() {
                const chatBtn = document.getElementById("chatbot-btn");
                const chatWidget = document.getElementById("chat-widget");
                const closeChat = document.getElementById("close-chat");
                const sendBtn = document.getElementById("send-btn");
                const userInput = document.getElementById("user-input");
                const chatMessages = document.getElementById("chat-messages");

                // Ouvrir / Fermer la fenêtre
                chatBtn.addEventListener("click", () => {
                    chatWidget.style.display = chatWidget.style.display === "flex" ? "none" : "flex";
                });
                closeChat.addEventListener("click", () => chatWidget.style.display = "none");

                // Envoyer un message
                sendBtn.addEventListener("click", sendMessage);
                userInput.addEventListener("keypress", function(e) {
                    if (e.key === "Enter") sendMessage();
                });

                async function sendMessage() {
                    const text = userInput.value.trim();
                    if (!text) return;

                    // 1. Afficher le message de l'utilisateur
                    chatMessages.innerHTML += `<div class="message mb-3 text-end"><span class="text-white-50">${text}</span> <span class="text-primary fw-bold">< Vous</span></div>`;
                    userInput.value = "";
                    
                    // Petit message d'attente
                    const waitId = "wait-" + Date.now();
                    chatMessages.innerHTML += `<div id="${waitId}" class="message mb-3"><span class="text-warning fw-bold">Hôte ></span> <i>Réflexion en cours...</i></div>`;
                    chatMessages.scrollTop = chatMessages.scrollHeight;

                    try {
                        // 2. Envoyer au serveur Python (Flask)
                        const response = await fetch("http://127.0.0.1:5000/chat", {
                            method: "POST",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify({ message: text })
                        });
                        const data = await response.json();

                        // 3. Afficher la réponse
                        document.getElementById(waitId).remove();
                        chatMessages.innerHTML += `<div class="message mb-3"><span class="text-warning fw-bold">Hôte ></span> ${data.reponse.replace(/\n/g, '<br>')}</div>`;
                        chatMessages.scrollTop = chatMessages.scrollHeight;

                    } catch (error) {
                        document.getElementById(waitId).remove();
                        chatMessages.innerHTML += `<div class="message mb-3 text-danger"><span class="fw-bold">Erreur ></span> Le croupier est indisponible (Vérifiez que le serveur Python tourne).</div>`;
                    }
                }
            });
        </script>
    </body>
</html>