{% extends 'base.html.twig' %}

{% block title %}Casino Royal | Quitte ou Double{% endblock %}

{% block body %}
<div class="bg-casino min-vh-100 py-5 d-flex flex-column justify-content-center" style="background: radial-gradient(circle, #1a0505 0%, #000000 100%);">

    {# --- HEADER --- #}
    <div class="position-absolute top-0 end-0 p-4 d-flex align-items-center gap-3" style="z-index: 1000;">
        <div class="text-end">
            <div class="text-white-50 fw-bold text-uppercase small" style="letter-spacing: 2px;">{{ app.user.pseudo|default('Joueur') }}</div>
            <div class="text-warning fw-bold fs-3"><span id="user-jetons">{{ app.user.jetons|default(0) }}</span> <small class="text-white-50" style="font-size: 0.5em;">JETONS</small></div>
        </div>
        <a href="/depotretrait" class="btn-add-funds shadow-lg"><span>+</span></a>
    </div>

    <div class="container text-center position-relative">
        
        {# --- TITRE --- #}
        <div class="mb-4">
            <h1 class="display-2 fw-bold text-uppercase mb-2 text-danger" style="text-shadow: 0px 0px 40px rgba(255, 0, 0, 0.8);">Quitte ou Double</h1>
            <div class="d-flex justify-content-center align-items-center gap-3">
                <div class="divider-red"></div>
                <button class="btn-info-circle-red" data-bs-toggle="modal" data-bs-target="#rulesModal">?</button>
                <div class="divider-red-reverse"></div>
            </div>
        </div>

        <div class="row justify-content-center align-items-center mt-5">
            
            {# --- ZONE CENTRALE : LA ROUE/PIÈCE --- #}
            <div class="col-12 mb-5">
                <div class="roue-wrapper mx-auto" id="roue-declencheur" title="Cliquez pour lancer la roue !">
                    <div class="roue-outer red-glow shadow-lg">
                        <div class="roue-inner d-flex align-items-center justify-content-center" id="roue-inner-spin">
                            <span class="display-1 fw-bold text-white shadow-text draw-number" id="drawNumber">?</span>
                        </div>
                    </div>
                    <div class="roue-pointer"></div>
                </div>
                <p class="text-danger mt-3 fw-bold small text-uppercase" id="spin-instruction" style="letter-spacing: 2px; animation: pulse 2s infinite;">
                    <i class="bi bi-hand-index-thumb"></i> Appuyez sur la roue pour jouer
                </p>
            </div>

            {# --- INTERFACE DE PARI --- #}
            <div class="col-12 col-md-8 col-lg-5">
                <div class="neon-card red-glow">
                    <div class="card-inner p-4">
                        <label class="form-label small text-uppercase fw-bold text-danger mb-3" style="letter-spacing: 1px;">SÉLECTIONNEZ VOTRE DESTIN</label>
                        
                        <div class="d-flex gap-3 mb-4">
                            <input type="radio" class="btn-check" name="betType" id="pair" autocomplete="off">
                            <label class="btn btn-outline-pari flex-fill py-3 fs-5" for="pair">PAIR</label>

                            <input type="radio" class="btn-check" name="betType" id="impair" autocomplete="off">
                            <label class="btn btn-outline-pari flex-fill py-3 fs-5" for="impair">IMPAIR</label>
                        </div>

                        <div class="input-group mb-4 px-3">
                            <span class="input-group-text bg-transparent border-0 text-white-50 fw-bold">MISE :</span>
                            <input type="number" id="bet-input" class="form-control bet-input-red" value="10" min="1">
                        </div>

                        {# BOÎTE DE RÉSULTAT INTÉGRÉE #}
                        <div id="result-box" class="mb-4 p-3 rounded d-none transition-all">
                            <h5 id="result-message" class="mb-0 fw-bold text-uppercase" style="letter-spacing: 1px;"></h5>
                        </div>

                        <a href="/menu" class="exit-btn d-block mt-4 text-white-50 text-uppercase small">Abandonner la partie</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# MODAL RÈGLES #}
<div class="modal fade" id="rulesModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark border-danger shadow-lg">
            <div class="modal-header border-0">
                <h5 class="modal-title text-danger fw-bold text-uppercase">Règles de la Table</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center py-4 text-white">
                <p class="text-white-50 small mb-4">La machine tire un nombre au hasard entre 1 et 100.</p>
                <div class="d-flex justify-content-between border-bottom border-secondary p-2 mb-2">
                    <span>Bon pronostic (Pair ou Impair)</span> <strong class="text-success">Gains x2</strong>
                </div>
                <div class="d-flex justify-content-between p-2">
                    <span>Mauvais pronostic</span> <strong class="text-danger">Mise Perdue</strong>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('turbo:load', () => {
    const roueDeclencheur = document.getElementById('roue-declencheur');
    const roueInnerSpin = document.getElementById('roue-inner-spin');
    const drawDisplay = document.getElementById('drawNumber');
    const jetonsDisplay = document.getElementById('user-jetons');
    const resultBox = document.getElementById('result-box');
    const resultMessage = document.getElementById('result-message');
    const betInput = document.getElementById('bet-input');
    const instructionText = document.getElementById('spin-instruction');

    let isSpinning = false;

    roueDeclencheur.addEventListener('click', async () => {
        if (isSpinning) return;

        const selectedRadio = document.querySelector('input[name="betType"]:checked');
        const mise = parseInt(betInput.value);

        if (!selectedRadio) {
            showResult("Veuillez choisir PAIR ou IMPAIR avant de lancer.", false);
            return;
        }
        if (isNaN(mise) || mise <= 0) {
            showResult("Mise invalide", false);
            return;
        }
        
        isSpinning = true;
        roueDeclencheur.style.cursor = 'not-allowed';
        instructionText.style.opacity = '0.3';
        resultBox.classList.add('d-none');
        
        // Démarre l'animation CSS de rotation rapide
        roueInnerSpin.classList.add('fast-spin');

        try {
            const response = await fetch('{{ path('app_qod_play') }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ typePari: selectedRadio.id, mise: mise })
            });

            const data = await response.json();
            
            if (data.error) {
                showResult(data.error, false);
                resetWheel();
                return;
            }

            // Animation des chiffres qui défilent à l'intérieur de la roue
            let speed = 20;
            let count = 0;
            
            function animateNumbers() {
                drawDisplay.innerText = Math.floor(Math.random() * 100) + 1;
                count++;
                
                if (count < 40) { // Accélération puis ralentissement
                    if(count > 25) speed += 10; 
                    setTimeout(animateNumbers, speed);
                } else {
                    // Fin de l'animation
                    roueInnerSpin.classList.remove('fast-spin');
                    drawDisplay.innerText = data.tirage;
                    
                    // Petit effet de "pop" quand le nombre s'arrête
                    drawDisplay.classList.add('pop-number');
                    setTimeout(() => drawDisplay.classList.remove('pop-number'), 300);

                    setTimeout(() => {
                        jetonsDisplay.innerText = data.nouveauSolde;
                        resetWheel();
                        
                        if (data.gain > 0) {
                            showResult(`✨ GAGNÉ ! + ${data.gain} JETONS ✨`, true);
                            drawDisplay.style.color = '#198754'; // Vert
                        } else {
                            const parite = data.tirage % 2 === 0 ? "Pair" : "Impair";
                            showResult(`Perdu... Le nombre était ${parite}.`, false);
                            drawDisplay.style.color = '#dc3545'; // Rouge
                        }
                    }, 500);
                }
            }
            
            // Lancer l'animation des nombres
            animateNumbers();

        } catch (e) {
            console.error(e);
            showResult("Erreur de communication", false);
            resetWheel();
        }
    });

    function resetWheel() {
        isSpinning = false;
        roueDeclencheur.style.cursor = 'pointer';
        instructionText.style.opacity = '1';
        roueInnerSpin.classList.remove('fast-spin');
    }

    function showResult(message, isWin) {
        resultBox.classList.remove('d-none', 'win-glow', 'lose-glow', 'text-success', 'text-danger');
        resultMessage.innerText = message;
        
        if (isWin) {
            resultBox.classList.add('win-glow', 'text-success');
        } else {
            resultBox.classList.add('lose-glow', 'text-danger');
        }
        
        // Remettre la couleur du nombre en blanc après quelques secondes
        if(!isSpinning) {
            setTimeout(() => {
                 drawDisplay.style.color = 'white';
            }, 3000);
        }
    }
});
</script>

<style>
    /* Design global */
    .divider-red { height: 1px; width: 120px; background: linear-gradient(to right, transparent, #ff4500); }
    .divider-red-reverse { height: 1px; width: 120px; background: linear-gradient(to left, transparent, #ff4500); }

    /* --- LA ROUE (LE DÉCLENCHEUR) --- */
    .roue-wrapper {
        position: relative;
        width: 220px;
        height: 220px;
        cursor: pointer;
        transition: transform 0.2s;
    }
    
    .roue-wrapper:hover { transform: scale(1.05); }
    .roue-wrapper:active { transform: scale(0.95); }

    .roue-outer {
        position: absolute; width: 100%; height: 100%;
        background: rgba(0, 0, 0, 0.9); border-radius: 50%;
        padding: 8px; overflow: hidden;
        box-shadow: 0 0 40px rgba(255, 69, 0, 0.4), inset 0 0 20px rgba(0,0,0,1);
        border: 2px solid #330000;
    }

    /* L'effet néon qui tourne autour (bordure lumineuse) */
    .roue-outer::before {
        content: ""; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%;
        background: conic-gradient(#ff0000, transparent, transparent, #ff4500, transparent, transparent, #ff0000);
        animation: rotate-neon 8s linear infinite;
    }

    /* L'intérieur de la roue qui tourne pendant l'animation */
    .roue-inner {
        position: relative; width: 100%; height: 100%;
        background: radial-gradient(circle, #220000 0%, #0a0a0a 80%);
        border-radius: 50%; z-index: 2;
        border: 4px solid #ff4500;
        box-shadow: inset 0 0 30px rgba(255, 0, 0, 0.3);
        transition: transform 0.1s;
    }

    /* Le petit pointeur en haut de la roue */
    .roue-pointer {
        position: absolute;
        top: -15px;
        left: 50%;
        transform: translateX(-50%);
        width: 0; 
        height: 0; 
        border-left: 15px solid transparent;
        border-right: 15px solid transparent;
        border-top: 25px solid #fff;
        z-index: 10;
        filter: drop-shadow(0 0 5px #ff4500);
    }

    /* Animation de rotation rapide pour le JS */
    .fast-spin {
        animation: rotate-fast 0.5s linear infinite;
    }

    .draw-number {
        font-size: 6rem;
        text-shadow: 0 0 20px rgba(255, 255, 255, 0.5);
        transition: color 0.3s ease;
    }
    
    .pop-number {
        animation: pop 0.3s ease-out;
    }

    /* --- INTERFACE DE PARI --- */
    .neon-card.red-glow {
        background: rgba(255, 69, 0, 0.05);
        border: 1px solid rgba(255, 69, 0, 0.3);
        border-radius: 20px; padding: 2px;
        box-shadow: 0 0 30px rgba(255, 69, 0, 0.1);
    }
    .card-inner { background: #0a0a0a; border-radius: 18px; }

    .btn-outline-pari { 
        border: 2px solid rgba(255, 69, 0, 0.4); 
        color: #ff4500; border-radius: 10px; font-weight: bold; 
        cursor: pointer; transition: 0.3s;
    }
    .btn-outline-pari:hover { background: rgba(255, 69, 0, 0.1); }
    .btn-check:checked + .btn-outline-pari { 
        background: #ff4500; color: white; 
        box-shadow: 0 0 20px rgba(255, 69, 0, 0.6); 
        border-color: #ff4500;
    }

    .bet-input-red {
        background: transparent !important; border: none !important;
        border-bottom: 2px solid #ff4500 !important; color: white !important;
        font-size: 1.5rem; font-weight: bold; text-align: center;
    }
    .bet-input-red:focus { box-shadow: none; border-color: #fff !important; }

    /* Effets de résultat */
    .win-glow { background: rgba(25, 135, 84, 0.1); border: 1px solid #198754; box-shadow: 0 0 15px rgba(25, 135, 84, 0.4); }
    .lose-glow { background: rgba(220, 53, 69, 0.1); border: 1px solid #dc3545; box-shadow: 0 0 15px rgba(220, 53, 69, 0.4); }
    .transition-all { transition: all 0.3s ease; }

    .btn-info-circle-red {
        background: transparent; border: 1px solid #ff4500; color: #ff4500;
        width: 40px; height: 40px; border-radius: 50%; transition: 0.3s;
    }
    .btn-info-circle-red:hover { background: #ff4500; color: white; box-shadow: 0 0 15px #ff4500;}

    .exit-btn { text-decoration: none; transition: 0.3s; }
    .exit-btn:hover { color: #ff4500 !important; text-decoration: underline; }
    
    .btn-add-funds {
        background: #ffc107; color: black; width: 45px; height: 45px;
        border-radius: 50%; display: flex; align-items: center; justify-content: center;
        text-decoration: none; font-size: 1.5rem; font-weight: bold; transition: 0.3s;
    }
    .btn-add-funds:hover { transform: scale(1.1); background: white; }

    /* --- ANIMATIONS --- */
    @keyframes rotate-neon { 100% { transform: rotate(360deg); } }
    @keyframes rotate-fast { 100% { transform: rotate(360deg); } }
    @keyframes pulse { 0% { opacity: 0.7; } 50% { opacity: 1; text-shadow: 0 0 10px #ff4500; } 100% { opacity: 0.7; } }
    @keyframes pop { 0% { transform: scale(1); } 50% { transform: scale(1.4); } 100% { transform: scale(1); } }
</style>
{% endblock %}