{% extends 'base.html.twig' %}

{% block title %}Casino Royal | Quitte ou Double{% endblock %}

{% block body %}
<div class="bg-casino min-vh-100 py-5 d-flex align-items-center" style="background: radial-gradient(circle, #1a0505 0%, #000000 100%);">

    {# --- HEADER --- #}
    <div class="position-absolute top-0 end-0 p-4 d-flex align-items-center gap-3" style="z-index: 1000;">
        <div class="text-end">
            <div class="text-white-50 fw-bold text-uppercase small" style="letter-spacing: 2px;">{{ app.user.pseudo|default('Joueur') }}</div>
            <div class="text-warning fw-bold fs-3"><span id="user-jetons">{{ app.user.jetons|default(0) }}</span> <small class="text-white-50" style="font-size: 0.5em;">JETONS</small></div>
        </div>
        <a href="/depotretrait" class="btn-add-funds shadow-lg"><span>+</span></a>
    </div>

    <div class="container text-center">
        <div class="mb-5">
            <h1 class="display-1 fw-bold text-uppercase mb-2 text-danger" style="text-shadow: 0px 0px 30px rgba(255, 0, 0, 0.6);">Quitte ou Double</h1>
            <div class="d-flex justify-content-center align-items-center gap-3">
                <div class="divider-red"></div>
                <button class="btn-info-circle-red" data-bs-toggle="modal" data-bs-target="#rulesModal">?</button>
                <div class="divider-red-reverse"></div>
            </div>
        </div>

        {# --- ZONE TIRAGE --- #}
        <div class="row justify-content-center mb-5">
            <div class="col-auto">
                <div class="coin-container red-glow shadow-lg">
                    <div class="coin-inner d-flex align-items-center justify-content-center">
                        <span class="display-1 fw-bold text-white shadow-text" id="drawNumber">?</span>
                    </div>
                </div>
            </div>
        </div>

        {# --- INTERFACE --- #}
        <div class="row justify-content-center">
            <div class="col-12 col-md-8 col-lg-5">
                <div class="neon-card red-glow">
                    <div class="card-inner p-4">
                        <label class="form-label small text-uppercase fw-bold text-danger mb-3">Votre Pari</label>
                        <div class="d-flex gap-2 mb-4">
                            <input type="radio" class="btn-check" name="betType" id="pair" autocomplete="off">
                            <label class="btn btn-outline-pari flex-fill" for="pair">PAIR</label>

                            <input type="radio" class="btn-check" name="betType" id="zero" autocomplete="off">
                            <label class="btn btn-outline-zero flex-fill" for="zero">ZÉRO</label>

                            <input type="radio" class="btn-check" name="betType" id="impair" autocomplete="off">
                            <label class="btn btn-outline-pari flex-fill" for="impair">IMPAIR</label>
                        </div>

                        <div class="input-group mb-4 px-3">
                            <span class="input-group-text bg-transparent border-0 text-white-50">MISE:</span>
                            <input type="number" id="bet-input" class="form-control bet-input-red" value="10" min="1">
                        </div>

                        <button id="btn-play" class="btn-play red w-100 mb-3">TENTER LE DESTIN</button>
                        <a href="/menu" class="exit-btn d-block mt-2">QUITTER LA TABLE</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# MODAL RÈGLES (Omis ici pour la brièveté, garde le tien) #}

<script>
document.addEventListener('DOMContentLoaded', () => {
    const btnPlay = document.getElementById('btn-play');
    const drawDisplay = document.getElementById('drawNumber');
    const jetonsDisplay = document.getElementById('user-jetons');

    btnPlay.addEventListener('click', async () => {
        const selectedRadio = document.querySelector('input[name="betType"]:checked');
        const mise = document.getElementById('bet-input').value;

        if (!selectedRadio) return alert("Choisissez : PAIR, ZÉRO ou IMPAIR !");
        
        btnPlay.disabled = true;
        drawDisplay.classList.add('text-muted');

        try {
            const response = await fetch('{{ path('app_qod_play') }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ typePari: selectedRadio.id, mise: mise })
            });

            const data = await response.json();
            if (data.error) throw new Error(data.error);

            // Animation de suspense
            let count = 0;
            const anim = setInterval(() => {
                drawDisplay.innerText = Math.floor(Math.random() * 37);
                if (++count > 20) {
                    clearInterval(anim);
                    drawDisplay.innerText = data.tirage;
                    drawDisplay.classList.remove('text-muted');
                    
                    jetonsDisplay.innerText = data.nouveauSolde;
                    btnPlay.disabled = false;
                    
                    if (data.gain > 0) alert("GAGNÉ ! +" + data.gain);
                }
            }, 50);

        } catch (e) {
            alert(e.message);
            btnPlay.disabled = false;
        }
    });
});
</script>

<style>
    /* Garde tes styles CSS ici, ils sont parfaits */
    .text-muted { opacity: 0.5; filter: blur(2px); }
    @keyframes rotate-neon { 100% { transform: rotate(360deg); } }
</style>
{% endblock %}